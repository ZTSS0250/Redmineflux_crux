<% content_for :sidebar do %>
  <%= render 'crux_project_sidebar/project_crux_sidebar' %>
<% end %>
<%= stylesheet_link_tag('crux_dashboard', plugin: 'redmineflux_crux') %>

<h2><%= l(:label_setting, :scope => :crux) %></h2>
<span class="crux-demo-notice">Demo preview — not live data</span>

<table class="list">
  <thead><tr><th>Setting</th><th>Value</th></tr></thead>
  <tbody>
    <% @settings.each do |setting| %>
      <tr>
        <td><%= setting[:key] %></td>
        <td><%= setting[:value] %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @show_usage %>
  <div class="crux-section-title">Usage</div>
  <p>Plan tier: <span class="crux-badge crux-badge-info"><%= @plan_tier %></span></p>

  <div class="crux-stats">
    <% @usage_stats.each do |stat| %>
      <div class="crux-stat-tile">
        <span class="crux-stat-value"><%= stat[:value] %></span>
        <span class="crux-stat-label"><%= stat[:label] %></span>
      </div>
    <% end %>
  </div>

  <div class="crux-section-title">Cost per Agent</div>
  <table class="list">
    <thead><tr><th>Agent</th><th>Cost</th></tr></thead>
    <tbody>
      <% @cost_per_agent.each do |agent| %>
        <tr>
          <td><%= agent[:name] %></td>
          <td><%= agent[:cost] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
