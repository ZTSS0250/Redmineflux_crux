<% content_for :sidebar do %>
  <%= render 'crux_project_sidebar/project_crux_sidebar' %>
<% end %>
<%= stylesheet_link_tag('crux_dashboard', plugin: 'redmineflux_crux') %>
<%= stylesheet_link_tag('crux_agents', plugin: 'redmineflux_crux') %>

<h2><%= l(:label_agent, :scope => :crux) %></h2>

<table class="list">
  <thead>
    <tr><th>Agent</th><th>Scope</th><th>Configuration</th></tr>
  </thead>
  <tbody>
    <% @agents.each do |agent| %>
      <tr>
        <td><%= agent.name %></td>
        <td>
          <% if agent.override? %>
            <span class="crux-badge crux-badge-info">Project override</span>
          <% else %>
            <span class="crux-badge crux-badge-muted">Global default</span>
          <% end %>
        </td>
        <td>
          <% if User.current.allowed_to?(:crux_manage_agents, @project) %>
            <%= form_with url: project_crux_agent_path(@project, agent), method: :patch, local: true, html: { class: 'crux-agent-config-form' } do |f| %>
              <label><%= f.check_box :enabled, checked: agent.enabled? %> Enabled</label>
              <label>Model <%= f.text_field :model, value: agent.model, size: 14 %></label>
              <label>Fallback <%= f.text_field :fallback_model, value: agent.fallback_model, size: 14 %></label>
              <label>Temp <%= f.number_field :temperature, value: agent.temperature, step: 0.1, min: 0, max: 1, size: 4 %></label>
              <%= f.submit 'Save' %>
            <% end %>
          <% else %>
            <%= agent.enabled? ? 'Enabled' : 'Disabled' %> — <%= agent.model %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
