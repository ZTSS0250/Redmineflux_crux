<%# ── Crux Project Sidebar ─────────────────────────────── %>
<%= stylesheet_link_tag('crux_sidebar', plugin: 'redmineflux_crux') %>

<script>
  $(document).ready(function() {
    var cruxMenu = $('#main-menu a.crux-ai');
    cruxMenu.addClass('selected');
  });
</script>

<div title="<%= l(:label_dashboard, :scope => :crux) %>" class="sidebar-crux-dashboard">
  <%= link_to project_crux_path(@project), class: 'btn-crux-dashboard', id: 'btn-crux-dashboard' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
    </svg>
  <% end %>
</div>

<div title="<%= l(:label_chat, :scope => :crux) %>" class="sidebar-crux-chat">
  <%= link_to project_crux_chat_path(@project), class: 'btn-crux-chat', id: 'btn-crux-chat' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  <% end %>
</div>

<div title="<%= l(:label_agent, :scope => :crux) %>" class="sidebar-crux-agents">
  <%= link_to project_crux_agents_path(@project), class: 'btn-crux-agents', id: 'btn-crux-agents' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
  <% end %>
</div>

<div title="<%= l(:label_billing, :scope => :crux) %>" class="sidebar-crux-billing">
  <%= link_to project_crux_billing_path(@project), class: 'btn-crux-billing', id: 'btn-crux-billing' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
      <line x1="1" y1="10" x2="23" y2="10"/>
    </svg>
  <% end %>
</div>

<div title="<%= l(:label_setting, :scope => :crux) %>" class="sidebar-crux-settings">
  <%= link_to project_crux_settings_path(@project), class: 'btn-crux-settings', id: 'btn-crux-settings' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
  <% end %>
</div>


