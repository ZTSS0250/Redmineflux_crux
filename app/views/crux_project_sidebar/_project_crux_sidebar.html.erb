<%# ── Crux Project Sidebar ─────────────────────────────── %>
<%= stylesheet_link_tag('crux_sidebar', plugin: 'redmineflux_crux') %>

<script>
  $(document).ready(function() {
    var cruxMenu = $('#main-menu a.crux-ai');
    cruxMenu.addClass('selected');
  });
</script>

<div title="<%= l(:label_dashboard, :scope => :crux) %>" class="sidebar-crux-dashboard">
  <%= link_to project_crux_path(@project), class: 'btn-crux-dashboard', id: 'btn-crux-dashboard' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
    </svg>
  <% end %>
</div>

<div title="<%= l(:label_chat, :scope => :crux) %>" class="sidebar-crux-chat">
  <%= link_to project_crux_chat_path(@project), class: 'btn-crux-chat', id: 'btn-crux-chat' do %>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  <% end %>
</div>

