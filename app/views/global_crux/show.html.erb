<% content_for :sidebar do %>
  <%= render 'crux_global_sidebar/global_crux_sidebar' %>
<% end %>
<%= stylesheet_link_tag('crux_dashboard', plugin: 'redmineflux_crux') %>

<h2><%= l(:label_dashboard, :scope => :crux) %></h2>
<span class="crux-demo-notice">Demo preview — not live data</span>

<div class="crux-stats">
  <% @stats.each do |stat| %>
    <div class="crux-stat-tile">
      <span class="crux-stat-value"><%= stat[:value] %></span>
      <span class="crux-stat-label"><%= stat[:label] %></span>
    </div>
  <% end %>
</div>

<div class="crux-section-title">Top Projects by AI Activity</div>
<table class="list">
  <thead><tr><th>Project</th><th>Runs</th></tr></thead>
  <tbody>
    <% @top_projects.each do |project| %>
      <tr>
        <td><%= project[:name] %></td>
        <td><%= project[:runs] %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="crux-section-title">Top Agents by Usage</div>
<table class="list">
  <thead><tr><th>Agent</th><th>Share</th></tr></thead>
  <tbody>
    <% @top_agents.each do |agent| %>
      <tr>
        <td><%= agent[:name] %></td>
        <td><%= agent[:share] %></td>
      </tr>
    <% end %>
  </tbody>
</table>
